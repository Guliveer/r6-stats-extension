{
  "manifest_version": 3,
  "name": "R6 Stats Extension",
  "version": "1.0.0",
  "description": "RP session balance on tracker.gg + quick links to R6 trackers",
  "permissions": ["storage"],
  "host_permissions": [
    "https://r6.tracker.network/*",
    "https://tracker.gg/r6siege/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://r6.tracker.network/r6siege/profile/*",
        "https://tracker.gg/r6siege/profile/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
